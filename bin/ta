#!/bin/bash
# ta — attach to an existing tmux session (switches client if already inside tmux).
# Usage: ta <session-name>

if [ -z "$1" ]; then
  echo "Usage: ta <session-name>"
  tmux list-sessions 2>/dev/null
  exit 1
fi

if ! tmux has-session -t "=$1" 2>/dev/null; then
  echo "Session '$1' not found. Available:"
  tmux list-sessions 2>/dev/null
  exit 1
fi

printf '\033]0;%s\007' "$1"
if [ -n "$TMUX" ]; then
  tmux switch-client -t "$1"
else
  tmux attach -t "$1"
fi
